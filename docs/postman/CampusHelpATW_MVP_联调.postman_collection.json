        {
          "name": "登录-Alice",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"campus_email\": \"{{aliceEmail}}\",\n  \"code\": \"{{verifyCode}}\",\n  \"password\": \"{{devPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/email/verify",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "email",
                "verify"
              ]
            },
            "description": "登录后将 token 写入 token/aliceToken"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "var res = pm.response.json();",
                  "var token = (res.data && res.data.token) || res.token || null;",
                  "if (token) {",
                  "  pm.collectionVariables.set('token', token);",
                  "  pm.collectionVariables.set('aliceToken', token);",
                  "}",
                  "var userId = (res.data && res.data.user && res.data.user.id) || (res.user && res.user.id);",
                  "if (userId) { pm.collectionVariables.set('aliceUserId', String(userId)); }"
                ]
              }
            }
          ]
        },
