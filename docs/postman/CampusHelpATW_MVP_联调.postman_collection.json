                "unread"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var res = pm.response.json();",
                  "var data = res.data || {};",
                  "if (typeof data.total_unread !== \"undefined\") pm.collectionVariables.set(\"chat_unread_total\", String(data.total_unread));",
                  "var chatId = pm.collectionVariables.get(\"chat_id\");",
                  "var items = data.items || [];",
                  "if (chatId && Array.isArray(items)) {",
                  "  var hit = items.find(function(it){ return String(it.chat_id) === String(chatId); });",
                  "  if (hit) {",
                  "    pm.collectionVariables.set(\"chat_unread_count\", String(hit.unread_count || 0));",
                  "    if (typeof hit.latest_message_id !== \"undefined\") pm.collectionVariables.set(\"latest_message_id\", String(hit.latest_message_id || 0));",
                  "    if (typeof hit.last_read_message_id !== \"undefined\") pm.collectionVariables.set(\"last_read_message_id\", String(hit.last_read_message_id || 0));",
                  "  }",
                  "}"
                ]
              }
            }
