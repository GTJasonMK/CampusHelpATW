                }
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "var res = pm.response.json();",
                  "var list = [];",
                  "if (Array.isArray(res.data)) list = res.data;",
                  "else if (res.data && Array.isArray(res.data.list)) list = res.data.list;",
                  "else if (Array.isArray(res.list)) list = res.list;",
                  "function setByTitle(title, key){",
                  "  var item = list.find(function(x){ return x && x.title === title; });",
                  "  if (item && item.id) pm.collectionVariables.set(key, String(item.id));",
                  "}",
                  "setByTitle('联调任务-01-待接单', 'task_open_id');",
                  "setByTitle('联调任务-04-已接单', 'task_accepted_id');",
                  "setByTitle('联调任务-06-进行中', 'task_in_progress_id');",
                  "setByTitle('联调任务-08-待确认', 'task_pending_confirm_id');",
                  "setByTitle('联调任务-09-已完成', 'task_done_id');",
                  "setByTitle('联调任务-10-申诉中', 'task_disputed_id');"
